def cmd_pr_list(args):
    """List pull requests."""
    repo = escape_repo(get_repo(args.repo))
    params = []
    if args.state:
        params.append(f"state={args.state}")
    query = "&".join(params)
    path = f"/repos/{repo}/pulls"
