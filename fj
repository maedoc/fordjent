def cmd_pr_get(args):
    """Get PR details."""
    repo = escape_repo(get_repo(args.repo))
    result = curl("GET", f"/repos/{repo}/pulls/{args.number}")
    if result:
        print(f"#{result.get('number')} {result.get('title')}")
