#!/usr/bin/env python3
"""
Forgejo CLI - Common Forgejo API operations without curl.
Reads credentials from environment or .env file.
"""

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path
from urllib.parse import quote

# Global state for URL override
_url_override = None
_json_output = False
_detected_repo = None  # Cached detected repo


def detect_repo():
    """Detect repository from git remote. Returns 'owner/repo' or None."""
    global _detected_repo
    
    if _detected_repo is not None:
        return _detected_repo if _detected_repo else None
    
    try:
        result = subprocess.run(
            ["git", "remote", "get-url", "origin"],
            capture_output=True, text=True, cwd=os.getcwd()
        )
        if result.returncode != 0:
            _detected_repo = ""
            return None
        
        url = result.stdout.strip()
        
        # Parse various URL formats:
        # SSH:     git@forgejo-local:duke/repo.git
        # SSH:     git@10.67.121.201:duke/repo.git  
        # HTTPS:   https://forgejo-local/duke/repo.git
        # HTTPS:   http://localhost:3000/duke/repo.git
        # HTTPS:   https://host/git/duke/repo.git (gitea-style path)
        
        import re
        
        # SSH format: user@host:owner/repo.git
        ssh_match = re.match(r'git@[^:]+:([^/]+)/([^/]+?)(?:\.git)?$', url)
        if ssh_match:
            _detected_repo = f"{ssh_match.group(1)}/{ssh_match.group(2)}"
            return _detected_repo
        
        # HTTPS format: https://host/.../owner/repo.git
        # Extract last two path segments as owner/repo
        https_match = re.match(r'https?://[^/]+/(.+?)(?:\.git)?$', url)
        if https_match:
            path = https_match.group(1)
            parts = path.rstrip('/').split('/')
            if len(parts) >= 2:
                _detected_repo = f"{parts[-2]}/{parts[-1]}"
                return _detected_repo
        
        _detected_repo = ""
        return None
    except Exception:
        _detected_repo = ""
        return None


def get_repo(repo_arg):
    """Get repo from arg or detect from git remote."""
    if repo_arg:
        return repo_arg
    detected = detect_repo()
    if not detected:
        print("Error: No repository specified and couldn't detect from git remote.", file=sys.stderr)
        print("Specify with 'owner/repo' or run from inside a git repository.", file=sys.stderr)
        sys.exit(1)
    return detected

# Try to load python-dotenv if available
try:
    from dotenv import load_dotenv
    load_dotenv(Path(__file__).parent / ".env")
except ImportError:
    pass


def load_config():
    """Load config from .fj file in current directory or parents."""
    global _url_override, _detected_repo
    # Check for .fj config file (like .git) - walk up directories
    cwd = Path.cwd()
    for p in [cwd] + list(cwd.parents):
        cfg_file = p / ".fj"
        if cfg_file.exists():
            try:
                import configparser
                config = configparser.ConfigParser()
                config.read(cfg_file)
                if 'forgejo' in config:
                    if 'url' in config['forgejo'] and not _url_override:
                        _url_override = config['forgejo']['url']
                    if 'token' in config['forgejo']:
                        os.environ.setdefault('FORGEJO_TOKEN', config['forgejo']['token'])
                    if 'user' in config['forgejo']:
                        os.environ.setdefault('FORGEJO_USER', config['forgejo']['user'])
                    if 'password' in config['forgejo']:
                        os.environ.setdefault('FORGEJO_PASSWORD', config['forgejo']['password'])
                    if 'repo' in config['forgejo']:
                        _detected_repo = config['forgejo']['repo']
                break
            except Exception:
                pass


def cmd_init(args):
    """Initialize .fj config file."""
    cfg_file = Path.cwd() / ".fj"
    if cfg_file.exists() and not args.force:
        print("Error: .fj already exists. Use --force to overwrite.", file=sys.stderr)
        sys.exit(1)
    
    # Priority: args.url > _url_override (global --url) > env var > default
    url = args.url or _url_override or os.environ.get('FORGEJO_URL', 'http://localhost:3000')
    
    content = f"""[forgejo]
url = {url}
"""
    if args.token:
        content += f"token = {args.token}\n"
    if args.user:
        content += f"user = {args.user}\n"
    if args.password:
        content += f"password = {args.password}\n"
    if args.repo:
        content += f"repo = {args.repo}\n"
    
    cfg_file.write_text(content)
    print(f"Created {cfg_file}")
    print("Config:")
    print(content)


def cmd_detect(args):
    """Show detected repository from git remote."""
    repo = detect_repo()
    if repo:
        print(f"Detected: {repo}")
    else:
        print("No repository detected from git remote.")


def get_config():
    """Get Forgejo configuration from environment."""
    url = _url_override or os.environ.get("FORGEJO_URL", "http://localhost:3000")
    token = os.environ.get("FORGEJO_TOKEN")
    user = os.environ.get("FORGEJO_USER", "fjadmin")
    password = os.environ.get("FORGEJO_PASSWORD", "REDACTED")
    return url, token, user, password


def curl(method, path, data=None, raw=False, silent=True):
    """Execute a curl request to Forgejo API."""
    url, token, user, password = get_config()
    full_url = f"{url.rstrip('/')}/api/v1{path}"
    
    cmd = ["curl", "-s"]
    if method != "GET":
        cmd.extend(["-X", method])
    
    # Auth: token takes precedence, then basic auth
    if token:
        cmd.extend(["-H", f"Authorization: token {token}"])
    else:
        cmd.extend(["-u", f"{user}:{password}"])
    
    if data and not raw:
        cmd.extend(["-H", "Content-Type: application/json"])
        if isinstance(data, dict):
            data = json.dumps(data)
        cmd.extend(["-d", data])
    elif data and raw:
        cmd.extend(["-d", data])
    
    cmd.append(full_url)
    
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        print(f"Error: {result.stderr}", file=sys.stderr)
        sys.exit(1)
    
    output = result.stdout.strip()
    if output:
        try:
            return json.loads(output)
        except json.JSONDecodeError:
            return output
    return None


def output(data):
    """Output data - either JSON or formatted."""
    if _json_output:
        print(json.dumps(data, indent=2))
    return data

def escape_repo(repo):
    """Escape repo path for URL (owner/repo -> owner%2Frepo)."""
    parts = repo.split("/")
    return "/".join(quote(p, safe="") for p in parts)


# === REPO COMMANDS ===

def cmd_repo_list(args):
    """List user repositories."""
    result = curl("GET", "/user/repos")
    if _json_output:
        output(result)
        return
    for repo in result or []:
        print(f"{repo['full_name']} ({repo.get('visibility', 'private')})")


def cmd_repo_create(args):
    """Create a new repository."""
    data = {"name": args.name}
    if args.private:
        data["private"] = True
    if args.description:
        data["description"] = args.description
    result = curl("POST", "/user/repos", data)
    if result:
        print(f"Created: {result.get('full_name', args.name)}")


# === ISSUE COMMANDS ===

def cmd_issue_list(args):
    """List issues in a repo."""
    repo = escape_repo(get_repo(args.repo))
    params = []
    if args.state:
        params.append(f"state={args.state}")
    if args.labels:
        params.append(f"labels={args.labels}")
    query = "&".join(params)
    path = f"/repos/{repo}/issues"
    if query:
        path += f"?{query}"
    
    result = curl("GET", path)
    if _json_output:
        output(result)
        return
    for issue in result or []:
        num = issue.get("number", "?")
        title = issue.get("title", "")
        state = issue.get("state", "?")
        print(f"#{num} [{state}] {title}")


def cmd_issue_get(args):
    """Get issue details."""
    repo = escape_repo(get_repo(args.repo))
    result = curl("GET", f"/repos/{repo}/issues/{args.number}")
    if result:
        print(f"#{result.get('number')} {result.get('title')}")
        print(f"State: {result.get('state')}")
        print(f"Author: {result.get('user', {}).get('login')}")
        print(f"\n{result.get('body', '')}")


def cmd_issue_create(args):
    """Create a new issue."""
    repo = escape_repo(get_repo(args.repo))
    data = {"title": args.title}
    if args.body:
        data["body"] = args.body
    if args.labels:
        data["labels"] = args.labels.split(",")
    result = curl("POST", f"/repos/{repo}/issues", data)
    if result:
        print(f"Created issue #{result.get('number')}: {result.get('html_url')}")


def cmd_issue_close(args):
    """Close an issue."""
    repo = escape_repo(get_repo(args.repo))
    result = curl("PATCH", f"/repos/{repo}/issues/{args.number}", {"state": "closed"})
    if result:
        print(f"Closed issue #{args.number}")


def cmd_issue_open(args):
    """Reopen an issue."""
    repo = escape_repo(get_repo(args.repo))
    result = curl("PATCH", f"/repos/{repo}/issues/{args.number}", {"state": "open"})
    if result:
        print(f"Reopened issue #{args.number}")


