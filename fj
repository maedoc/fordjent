# === FILE COMMANDS ===

def cmd_file_list(args):
    """List files in a repo directory."""
    repo = escape_repo(get_repo(args.repo))
    ref = args.ref or "main"
    path = args.path or ""
    result = curl("GET", f"/repos/{repo}/contents/{path}?ref={ref}")
    if result:
        if _json_output:
            output(result)
            return
        # Handle error response
        if isinstance(result, dict) and "message" in result:
            print(f"Error: {result.get('message')}", file=sys.stderr)
            return
        # Result is a list of file/directory entries
        if isinstance(result, list):
            for entry in result:
                ftype = "[DIR] " if entry.get("type") == "dir" else "      "
                name = entry.get("name", "?")
                print(f"{ftype}{name}")
        else:
            # Single file returned
            print(result.get("name", "?"))


def cmd_file_get(args):
    """Get file contents from repo."""
    repo = escape_repo(get_repo(args.repo))
    ref = args.ref or "main"
    result = curl("GET", f"/repos/{repo}/contents/{args.path}?ref={ref}")
    if result:
        if _json_output:
            output(result)
            return
        import base64
        content = result.get("content", "")
        if result.get("encoding") == "base64":
            try:
                print(base64.b64decode(content).decode("utf-8"))
            except:
                print(content)
        else:
            print(content)


def cmd_file_create(args):
    """Create or update a file."""
    repo = escape_repo(get_repo(args.repo))
    import base64
    content_b64 = base64.b64encode(args.content.encode()).decode()
    data = {
        "message": args.message,
        "content": content_b64,
    }
    if args.sha:
        data["sha"] = args.sha  # Required for update
    result = curl("POST", f"/repos/{repo}/contents/{args.path}", data)
    if result:
        print(f"Created/updated {args.path} in {args.repo}")


