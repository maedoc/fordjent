def main():
    global _url_override, _json_output
    
    # Pre-parse to get global flags before subcommand parsing
    pre_parser = argparse.ArgumentParser(add_help=False)
    pre_parser.add_argument("--url", "-u", help="Forgejo URL")
    pre_parser.add_argument("--json", "-j", action="store_true", help="Output as JSON")
    pre_args, remaining = pre_parser.parse_known_args()
    
    if pre_args.url:
        _url_override = pre_args.url
    if pre_args.json:
        _json_output = True
    
    parser = argparse.ArgumentParser(
        description="""Forgejo CLI - Common API operations

Examples:
  fj issue list owner/repo                    # List open issues
  fj issue create owner/repo "Title" --body "Description"
  fj issue comment owner/repo 42 "My comment"  # Add comment
  fj pr list owner/repo --state all           # List all PRs
  fj pr files owner/repo 5                    # Show changed files
  fj pr merge owner/repo 5                    # Merge PR
  fj file list owner/repo pkg/                # List directory
  fj file get owner/repo README.md            # Get file
  fj comment add owner/repo 42 "Reply..."     # Add comment
  fj label add owner/repo 42 bug,urgent       # Add labels

Repo can be omitted if running from inside a git repo (auto-detected).
""",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--url", "-u", help="Forgejo URL (default: $FORGEJO_URL or http://localhost:3000)")
    parser.add_argument("--json", "-j", action="store_true", help="Output as JSON")
    subparsers = parser.add_subparsers(dest="command", help="Command to run")
    
    # === REPO ===
    repo_parser = subparsers.add_parser("repo", help="Repository operations")
    repo_sub = repo_parser.add_subparsers(dest="subcommand")
    
    p = repo_sub.add_parser("list", help="List repositories")
    p.set_defaults(func=cmd_repo_list)
    
    p = repo_sub.add_parser("create", help="Create repository")
    p.add_argument("name", help="Repository name")
    p.add_argument("--private", action="store_true", help="Make private")
    p.add_argument("--description", help="Repository description")
    p.set_defaults(func=cmd_repo_create)
    
    # === ISSUE ===
    issue_parser = subparsers.add_parser("issue", help="Issue operations")
    issue_sub = issue_parser.add_subparsers(dest="subcommand")
    
    p = issue_sub.add_parser("list", help="List issues")
    p.add_argument("repo", nargs="?", default=None, help="Repository (owner/repo), auto-detected from git")
    p.add_argument("--state", choices=["open", "closed", "all"], default="open")
    p.add_argument("--labels", help="Filter by labels (comma-separated)")
    p.set_defaults(func=cmd_issue_list)
    
    p = issue_sub.add_parser("get", help="Get issue details")
    p.add_argument("repo", nargs="?", default=None, help="Repository (owner/repo), auto-detected from git")
    p.add_argument("number", type=int, help="Issue number")
    p.set_defaults(func=cmd_issue_get)
    
    p = issue_sub.add_parser("create", help="Create issue")
    p.add_argument("repo", nargs="?", default=None, help="Repository (owner/repo), auto-detected from git")
    p.add_argument("title", help="Issue title")
    p.add_argument("--body", help="Issue body")
    p.add_argument("--labels", help="Labels (comma-separated)")
    p.set_defaults(func=cmd_issue_create)
    
    p = issue_sub.add_parser("close", help="Close issue")
    p.add_argument("repo", nargs="?", default=None, help="Repository (owner/repo), auto-detected from git")
    p.add_argument("number", type=int, help="Issue number")
    p.set_defaults(func=cmd_issue_close)
    
