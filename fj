    data = {"Do": merge_style}
    if args.message:
        data["merge_message"] = args.message
    result = curl("POST", f"/repos/{repo}/pulls/{args.number}/merge", data)
    if result:
        print(f"Merged PR #{args.number}")


def cmd_pr_create(args):
    """Create a pull request."""
    repo = escape_repo(get_repo(args.repo))
    data = {
        "title": args.title,
        "head": args.head,
        "base": args.base or "main",
    }
    if args.body:
        data["body"] = args.body
    result = curl("POST", f"/repos/{repo}/pulls", data)
    if result:
        print(f"Created PR #{result.get('number')}: {result.get('html_url')}")


def cmd_pr_close(args):
    """Close a pull request."""
    repo = escape_repo(get_repo(args.repo))
    result = curl("PATCH", f"/repos/{repo}/pulls/{args.number}", {"state": "closed"})
    if result:
        print(f"Closed PR #{args.number}")


def cmd_pr_files(args):
    """List files changed in a PR."""
    repo = escape_repo(get_repo(args.repo))
    result = curl("GET", f"/repos/{repo}/pulls/{args.number}/files")
    if result:
        if _json_output:
            output(result)
            return
        # Handle error response
        if isinstance(result, dict) and "message" in result:
            print(f"Error: {result.get('message')}", file=sys.stderr)
            return
        if not isinstance(result, list):
            print(f"Unexpected response: {result}", file=sys.stderr)
            return
        for f in result:
            status = f.get("status", "?")
            fname = f.get("filename", "?")
            additions = f.get("additions", 0)
            deletions = f.get("deletions", 0)
            status_map = {"added": "A", "modified": "M", "removed": "D", "renamed": "R"}
            s = status_map.get(status, status[0].upper() if status else "?")
            print(f"{s} {fname} (+{additions}/-{deletions})")


