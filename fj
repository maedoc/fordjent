    data = {
        "type": "forgejo",
        "config": {
            "url": args.url,
            "content_type": "json",
        },
        "events": args.events.split(",") if args.events else ["push"],
        "active": True,
    }
    if args.secret:
        data["config"]["secret"] = args.secret
    result = curl("POST", f"/repos/{repo}/hooks", data)
    if result:
        print(f"Created webhook #{result.get('id')}: {args.url}")


def cmd_hook_delete(args):
    """Delete a webhook."""
    repo = escape_repo(get_repo(args.repo))
    curl("DELETE", f"/repos/{repo}/hooks/{args.id}")
    print(f"Deleted webhook #{args.id}")


